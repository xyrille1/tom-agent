# Copy this file to .env and fill in your own free-tier API keys.
# .env is gitignored — never commit real keys.
#
# All free to obtain:
#   GEMINI_API_KEY       -> https://aistudio.google.com/apikey (permanent free tier, no card)
#   GROQ_API_KEY         -> https://console.groq.com/keys (permanent free tier, no card)
#   ANTHROPIC_API_KEY    -> https://console.anthropic.com (one-time free signup credit, no card charge)
#   HUGGINGFACE_API_KEY  -> https://huggingface.co/settings/tokens (free monthly inference credits, no card)
#   CLOUDFLARE_API_TOKEN -> https://dash.cloudflare.com/profile/api-tokens (needs "Workers AI: Read/Edit" scope)
#   CLOUDFLARE_ACCOUNT_ID-> visible on any page of the Cloudflare dashboard (not secret, but required)
#
# You only need enough of these to cover the models you want to compare --
# any provider left blank is automatically skipped by the batch runner.

GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
